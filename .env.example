# ============================================================
# Hermes Work Agent — 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================

# ── DeepSeek API（必填）──────────────────────────────────────
# 所有 AI 对话和报告生成都依赖此 key
# 获取：https://platform.deepseek.com → API Keys → Create
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot（必填，推送提醒用）──────────────────────────
# Token 获取：Telegram 搜索 @BotFather → /newbot → 按提示操作
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Chat ID 获取方法：
#   1. 填好 TOKEN 后运行：python main.py
#   2. 在 Telegram 向你的 bot 发一条消息
#   3. 访问：https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. 找 result[0].message.chat.id，填入下方
TELEGRAM_CHAT_ID=987654321

# ── Gemini API（可选，OCR 图片识别专用）─────────────────────
# 未填则图片识别功能不可用（其他功能正常）
# 获取：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Notion 双向同步（可选）────────────────────────────────────
# 未填则 Notion 功能不可用（本地任务追踪正常）
#
# NOTION_TOKEN 获取：
#   1. 访问 https://www.notion.so/my-integrations
#   2. New integration → 填名称 → Submit
#   3. 复制 Internal Integration Token（格式：ntn_xxx）
NOTION_TOKEN=

# NOTION_PARENT_PAGE_ID 获取：
#   1. 在 Notion 打开目标页面
#   2. Share → Invite → 授权你的 integration
#   3. 复制页面 URL 末尾 32 位 ID
NOTION_PARENT_PAGE_ID=

# ── Web UI 密码（可选，默认 changeme）──────────────────────────
UI_PASSWORD=changeme

# ── Web Search (optional) ─────────────────────────────────────
# Hermes uses DuckDuckGo by default — no key needed.
# Set TAVILY_API_KEY for better AI-optimised results: tavily.com
TAVILY_API_KEY=

# ── Gmail (optional) ──────────────────────────────────────────
# Lets Hermes read and search your inbox.
# Setup (2 min):
#   1. Turn on 2-step verification on your Google account
#   2. Go to myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
#   4. Paste the 16-char password below
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── LLM provider ──────────────────────────────────────────────
# TODO: future support for openai / anthropic / local models
LLM_PROVIDER=deepseek

# ── 端口（Railway 自动注入，本地默认 8000）─────────────────────
PORT=8000

# ── 数据库路径（可选，Railway Volume 时填写）──────────────────
# 示例（Railway）：DB_PATH=/app/data/tasks.db
DB_PATH=
