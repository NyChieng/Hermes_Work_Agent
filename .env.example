# ============================================================
# Work Progress Agent — 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================

# ── DeepSeek API ─────────────────────────────────────────────
# 获取：https://platform.deepseek.com → API Keys → Create
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot ──────────────────────────────────────────────
# Token 获取：Telegram 搜索 @BotFather → /newbot → 按提示操作
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Chat ID 获取（4 步）：
#   1. 先填好 TOKEN，运行：python main.py
#   2. 在 Telegram 向你的 bot 发任意一条消息
#   3. 浏览器打开：https://api.telegram.org/bot<你的TOKEN>/getUpdates
#   4. 找 result[0].message.chat.id，填入下方
TELEGRAM_CHAT_ID=987654321

# ── Notion 双向同步（可选）────────────────────────────────────
# NOTION_TOKEN 获取：
#   1. 访问 https://www.notion.so/my-integrations
#   2. New integration → 输入名称 → Submit
#   3. 复制 Internal Integration Token（格式：secret_xxx）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NOTION_PARENT_PAGE_ID 获取：
#   1. 在 Notion 打开一个页面（agent 会在这个页面下建数据库）
#   2. 右上角 Share → Invite → 找到你的 integration → 授权
#   3. 复制页面 URL 中最后那段 32 位十六进制 ID
#      例：notion.so/My-Page-abcdef1234567890abcdef1234567890
#      → NOTION_PARENT_PAGE_ID=abcdef1234567890abcdef1234567890
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web UI（api.py + main.py 用）────────────────────────────
# 访问 Web UI 时需要输入此密码（任意字符串）
UI_PASSWORD=changeme

# Railway 部署时会自动注入 PORT，本地默认 8000
PORT=8000
